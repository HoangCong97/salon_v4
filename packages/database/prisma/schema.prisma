datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model SaasPlan {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(255)
  code        String    @unique @db.VarChar(50)
  price       Decimal   @default(0) @db.Decimal(15, 0)
  maxBranches Int       @default(1) @map("max_branches")
  maxStaff    Int       @default(5) @map("max_staff")
  features    String[]  @db.VarChar(255)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  tenants     Tenant[]
  invoices    SaasInvoice[]

  @@map("saas_plans")
}

model SaasInvoice {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  planId        String?   @map("plan_id") @db.Uuid
  invoiceNumber String    @unique @map("invoice_number") @db.VarChar(100)
  amount        Decimal   @default(0) @db.Decimal(15, 0)
  paymentMethod String?   @map("payment_method") @db.VarChar(100)
  paymentStatus String    @default("PENDING") @map("payment_status") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  tenant        Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan          SaasPlan? @relation(fields: [planId], references: [id], onDelete: SetNull)

  @@map("saas_invoices")
}

model Tenant {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name      String    @db.VarChar(255)
  ownerName String?   @map("owner_name") @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  email     String?   @db.VarChar(255)
  address   String?   @db.Text
  brandName     String?   @map("brand_name") @db.VarChar(255)
  slogan        String?   @db.VarChar(255)
  logoUrl       String?   @map("logo_url")
  bannerUrl     String?   @map("banner_url")
  hotline       String?   @db.VarChar(50)
  fanpageUrl    String?   @map("fanpage_url")
  instagramUrl  String?   @map("instagram_url")
  tiktokUrl     String?   @map("tiktok_url")
  websiteUrl    String?   @map("website_url")
  status        String    @default("ACTIVE") @db.VarChar(50)
  planId        String?   @map("plan_id") @db.Uuid
  planStartedAt DateTime? @map("plan_started_at") @db.Timestamptz
  planExpiresAt DateTime? @map("plan_expires_at") @db.Timestamptz
  planStatus    String    @default("TRIAL") @map("plan_status") @db.VarChar(50)
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  plan                SaasPlan?                  @relation(fields: [planId], references: [id], onDelete: SetNull)
  branches            Branch[]
  roles               Role[]
  users               User[]
  customers           Customer[]
  customerPoints      CustomerPoint[]
  services            Service[]
  serviceCategories   ServiceCategory[]
  inventories         Inventory[]
  servicePackages     ServicePackage[]
  purchasedPackages   CustomerPurchasedPackage[]
  packageUsageHistory PackageUsageHistory[]
  bookings            Booking[]
  reviews             CustomerReview[]
  invoices            Invoice[]
  commissionTemplates CommissionTemplate[]
  employeeShifts      EmployeeShift[]
  employeeDailyTurns  EmployeeDailyTurn[]
  employeeAttendances EmployeeAttendance[]
  salaryConfigs       EmployeeSalaryConfig[]
  salaryAdvances      SalaryAdvance[]
  monthlyPayrolls     EmployeeMonthlyPayroll[]
  dailyRevenueReports DailyRevenueReport[]
  dailyEmployeeRev    DailyEmployeeRevenue[]
  dailyBranchRev      DailyBranchRevenue[]
  expenditures        RevenueExpenditure[]
  saasInvoices        SaasInvoice[]

  @@map("tenants")
}

model Branch {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId  String    @map("tenant_id") @db.Uuid
  name      String    @db.VarChar(255)
  phone     String?   @db.VarChar(50)
  email     String?   @db.VarChar(255)
  address   String?
  brandName    String?   @map("brand_name") @db.VarChar(255)
  slogan       String?   @db.VarChar(255)
  logoUrl      String?   @map("logo_url")
  bannerUrl    String?   @map("banner_url")
  hotline      String?   @db.VarChar(50)
  fanpageUrl   String?   @map("fanpage_url")
  instagramUrl String?   @map("instagram_url")
  tiktokUrl    String?   @map("tiktok_url")
  websiteUrl   String?   @map("website_url")
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  tenant              Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userBranches        UserBranch[]
  customers           Customer[]
  customerPoints      CustomerPoint[]
  services            Service[]
  inventories         Inventory[]
  servicePackages     ServicePackage[]
  purchasedPackages   CustomerPurchasedPackage[]
  packageUsageHistory PackageUsageHistory[]
  bookings            Booking[]
  reviews             CustomerReview[]
  invoices            Invoice[]
  employeeShifts      EmployeeShift[]
  employeeDailyTurns  EmployeeDailyTurn[]
  employeeAttendances EmployeeAttendance[]
  salaryConfigs       EmployeeSalaryConfig[]
  salaryAdvances      SalaryAdvance[]
  monthlyPayrolls     EmployeeMonthlyPayroll[]
  dailyRevenueReports DailyRevenueReport[]
  dailyEmployeeRev    DailyEmployeeRevenue[]
  dailyBranchRev      DailyBranchRevenue[]
  expenditures        RevenueExpenditure[]

  @@map("branches")
}

model Role {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  name        String    @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  slug        String    @db.VarChar(100)
  groupName   String    @map("group_name") @db.VarChar(100)
  name        String    @db.VarChar(100)
  description String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permissions")
}

model RolePermission {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId], map: "uq_role_permissions_link")
  @@map("role_permissions")
}

model User {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  roleId     String?   @map("role_id") @db.Uuid
  name       String    @db.VarChar(255)
  loginId    String    @default("") @map("login_id") @db.VarChar(255)
  email      String?   @db.VarChar(255)
  password   String    @db.VarChar(255)
  phone      String?   @db.VarChar(50)
  sex        String?   @db.VarChar(10)
  avatar     String?
  baseSalary Decimal   @default(0) @map("base_salary") @db.Decimal(15, 0)
  status     String    @default("ACTIVE") @db.VarChar(50)
  note       String?
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  tenant          Tenant                 @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  role            Role?                  @relation(fields: [roleId], references: [id], onDelete: SetNull)
  userBranches    UserBranch[]
  settings        UserSetting[]
  bookingDetails  BookingDetail[]
  invoices        Invoice[]
  invoiceItems    InvoiceItem[]
  shifts          EmployeeShift[]
  dailyTurns      EmployeeDailyTurn[]
  attendances     EmployeeAttendance[]
  salaryConfigs   EmployeeSalaryConfig[]
  salaryAdvances  SalaryAdvance[]
  monthlyPayrolls EmployeeMonthlyPayroll[]
  dailyEmployeeRev DailyEmployeeRevenue[]

  @@map("users")
}

model UserBranch {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  branchId  String    @map("branch_id") @db.Uuid
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  branch Branch @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@map("user_branches")
}

model UserSetting {
  id                 String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId             String    @map("user_id") @db.Uuid
  theme              String    @default("dark") @db.VarChar(50)
  language           String    @default("vi") @db.VarChar(10)
  timezone           String    @default("Asia/Ho_Chi_Minh") @db.VarChar(100)
  receiveNotification Boolean   @default(true) @map("receive_notification")
  receiveSms         Boolean   @default(false) @map("receive_sms")
  receiveEmail       Boolean   @default(false) @map("receive_email")
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt          DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt          DateTime? @map("deleted_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

model Customer {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  branchId         String?   @map("branch_id") @db.Uuid
  name             String    @db.VarChar(255)
  phone            String?   @db.VarChar(50)
  email            String?   @db.VarChar(255)
  password         String?   @db.VarChar(255)
  credibilityScore Int       @default(100) @map("credibility_score")
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch?                    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  points            CustomerPoint[]
  purchasedPackages CustomerPurchasedPackage[]
  packageUsage      PackageUsageHistory[]
  bookings          Booking[]
  reviews           CustomerReview[]
  invoices          Invoice[]

  @@map("customers")
}

model CustomerPoint {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  branchId   String?   @map("branch_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  point      Int       @default(0)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)

  @@map("customer_points")
}

model Service {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId        String    @map("tenant_id") @db.Uuid
  branchId        String?   @map("branch_id") @db.Uuid
  name            String    @db.VarChar(255)
  serviceCategory String?   @map("service_category") @db.VarChar(100)
  categoryId      String?   @map("category_id") @db.Uuid
  price           Decimal   @default(0) @db.Decimal(15, 0)
  discountAmount  Decimal?  @default(0) @map("discount_amount") @db.Decimal(15, 0)
  additionalPrices Decimal[] @default([]) @map("additional_prices") @db.Decimal(15, 0)
  duration        Int?      // In minutes
  imageUrl        String?   @map("image_url")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz

  tenant                Tenant                  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch                Branch?                 @relation(fields: [branchId], references: [id], onDelete: SetNull)
  category              ServiceCategory?        @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  packageDetails        ServicePackageDetail[]
  purchasedPackageUsage PackageUsageHistory[]
  bookingDetails        BookingDetail[]

  @@map("services")
}

model Inventory {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  branchId      String?   @map("branch_id") @db.Uuid
  name          String    @db.VarChar(255)
  costPrice     Decimal   @default(0) @map("cost_price") @db.Decimal(15, 0)
  sellPrice     Decimal   @default(0) @map("sell_price") @db.Decimal(15, 0)
  quantity      Int       @default(0)
  discountAmount Decimal?  @default(0) @map("discount_amount") @db.Decimal(15, 0)
  imageUrl      String?   @map("image_url")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch Branch? @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@map("inventories")
}

model ServicePackage {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  branchId      String?   @map("branch_id") @db.Uuid
  name          String    @db.VarChar(255)
  description   String?
  price         Decimal   @default(0) @db.Decimal(15, 0)
  discountAmount Decimal?  @default(0) @map("discount_amount") @db.Decimal(15, 0)
  duration      Int?      // Expiration period in days
  imageUrl      String?   @map("image_url")
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  tenant            Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch            Branch?                    @relation(fields: [branchId], references: [id], onDelete: SetNull)
  details           ServicePackageDetail[]
  purchasedPackages CustomerPurchasedPackage[]

  @@map("service_packages")
}

model ServicePackageDetail {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  servicePackageId String    @map("service_package_id") @db.Uuid
  serviceId        String    @map("service_id") @db.Uuid
  quantity         Int       @default(1)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  package ServicePackage @relation(fields: [servicePackageId], references: [id], onDelete: Cascade)
  service Service        @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("service_package_details")
}

model CustomerPurchasedPackage {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  branchId         String?   @map("branch_id") @db.Uuid
  customerId       String    @map("customer_id") @db.Uuid
  servicePackageId String    @map("service_package_id") @db.Uuid
  quantity         Int       @default(0)
  usedQuantity     Int       @default(0) @map("used_quantity")
  expiryDate       DateTime? @map("expiry_date") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch       Branch?        @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer     Customer       @relation(fields: [customerId], references: [id], onDelete: Cascade)
  package      ServicePackage @relation(fields: [servicePackageId], references: [id], onDelete: Cascade)
  usages       PackageUsageHistory[]

  @@map("customer_purchased_packages")
}

model PackageUsageHistory {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId   String    @map("tenant_id") @db.Uuid
  branchId   String?   @map("branch_id") @db.Uuid
  customerId String    @map("customer_id") @db.Uuid
  packageId  String    @map("package_id") @db.Uuid
  serviceId  String    @map("service_id") @db.Uuid
  quantity   Int       @default(1)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz

  tenant   Tenant                   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?                  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer Customer                 @relation(fields: [customerId], references: [id], onDelete: Cascade)
  purchase CustomerPurchasedPackage @relation(fields: [packageId], references: [id], onDelete: Cascade)
  service  Service                  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@map("package_usage_history")
}

model Booking {
  id            String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId      String    @map("tenant_id") @db.Uuid
  branchId      String    @map("branch_id") @db.Uuid
  customerId    String?   @map("customer_id") @db.Uuid
  startTime     DateTime  @map("start_time") @db.Timestamptz
  endTime       DateTime  @map("end_time") @db.Timestamptz
  status        String    @default("PENDING") @db.VarChar(50)
  source        String    @default("WALK_IN") @db.VarChar(50)
  customerName  String?   @map("customer_name") @db.VarChar(255)
  customerPhone String?   @map("customer_phone") @db.VarChar(50)
  note          String?
  createdAt     DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt     DateTime? @map("deleted_at") @db.Timestamptz

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch         Branch          @relation(fields: [branchId], references: [id], onDelete: Cascade)
  customer       Customer?       @relation(fields: [customerId], references: [id], onDelete: SetNull)
  bookingDetails BookingDetail[]
  reviews        CustomerReview[]
  invoices       Invoice[]

  @@map("bookings")
}

model BookingDetail {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  bookingId String    @map("booking_id") @db.Uuid
  serviceId String    @map("service_id") @db.Uuid
  staffId   String?   @map("staff_id") @db.Uuid
  startTime DateTime? @map("start_time") @db.Timestamptz
  duration  Int?      // Override duration in minutes
  status    String    @default("PENDING") @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz

  booking Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  service Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)
  staff   User?    @relation(fields: [staffId], references: [id], onDelete: SetNull)

  @@map("booking_details")
}

model CustomerReview {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId    String    @map("tenant_id") @db.Uuid
  branchId    String?   @map("branch_id") @db.Uuid
  customerId  String    @map("customer_id") @db.Uuid
  bookingId   String?   @map("booking_id") @db.Uuid
  ratingStars Int       @map("rating_stars")
  comment     String?
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  branch   Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  booking  Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)

  @@map("customer_reviews")
}

model Invoice {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  branchId       String    @map("branch_id") @db.Uuid
  bookingId      String?   @map("booking_id") @db.Uuid
  customerId     String?   @map("customer_id") @db.Uuid
  staffId        String?   @map("staff_id") @db.Uuid
  startTime      DateTime? @map("start_time") @db.Timestamptz
  endTime        DateTime? @map("end_time") @db.Timestamptz
  totalPrice     Decimal   @default(0) @map("total_price") @db.Decimal(15, 0)
  discountAmount Decimal   @default(0) @map("discount_amount") @db.Decimal(15, 0)
  finalAmount    Decimal   @default(0) @map("final_amount") @db.Decimal(15, 0)
  paymentMethod  String    @default("CASH") @map("payment_method") @db.VarChar(50)
  paymentStatus  String    @default("UNPAID") @map("payment_status") @db.VarChar(50)
  status         String    @default("COMPLETED") @db.VarChar(50)
  imageTransaction String? @map("image_transaction")
  note           String?
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz
