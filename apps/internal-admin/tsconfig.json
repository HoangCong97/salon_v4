{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2020"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "baseUrl": "./",
    "paths": {
      "@salon/shared-types": ["../../packages/shared-types/src/index.ts"],
      "@salon/shared-utils": ["../../packages/shared-utils/src/index.ts"],
      "@salon/database": ["../../packages/database/src/index.ts"]
    }
  },
  "include": ["src"]
}
